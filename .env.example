# ── MadEyE 경로 설정 ──────────────────────────────────────────────────────
# Windows
MADEYE_PYTHON=C:\Users\<username>\.madeye\.venv\Scripts\python.exe
MADEYE_SCRIPT=C:\Users\<username>\.madeye\run_madeye.py

# Linux / NAS
# MADEYE_PYTHON=/root/.madeye/.venv/bin/python3
# MADEYE_SCRIPT=/root/.madeye/run_madeye.py

# ── 서버 설정 ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000
ORIGIN=http://<NAS-IP>:3000
